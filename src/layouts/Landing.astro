---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content="Record any API. Synthesize a deterministic local twin. Keep it aligned automatically as upstream APIs drift. No spec required." />
    <link rel="canonical" href="https://wraith.cx" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="top-nav">
      <div class="nav-inner">
        <a href="/" class="nav-brand">wraith</a>
        <div class="nav-links">
          <a href="/quickstart/">Quickstart</a>
          <a href="/twin-lifecycle/">Lifecycle</a>
          <a href="/configuration/">Config</a>
          <a href="https://github.com/bobisme/wraith-releases" class="nav-github">GitHub</a>
        </div>
      </div>
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  /* ============================================================
     Reset & Base
     ============================================================ */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    color-scheme: dark;
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #131313;
    color: #d4d4d4;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #ededed;
  }

  a {
    color: #d2bcfb;
    text-decoration: none;
    transition: color 0.15s;
  }

  a:hover {
    color: #ede6ff;
  }

  code {
    font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
    font-size: 0.875em;
  }

  /* ============================================================
     Navigation
     ============================================================ */
  .top-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 2rem;
    background: #0e0e0eee;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 1.125rem;
    color: #ededed;
    letter-spacing: 0.05em;
    text-transform: lowercase;
  }

  .nav-brand:hover {
    color: #d2bcfb;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-links a {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    color: #a3a3a3;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.15s;
  }

  .nav-links a:hover {
    color: #d2bcfb;
  }

  .nav-github {
    background: linear-gradient(135deg, #d2bcfb 0%, #b19cd9 100%);
    color: #0e0e0e !important;
    padding: 0.4rem 1rem;
    font-weight: 600 !important;
    transition: all 0.25s ease !important;
  }

  .nav-github:hover {
    color: #0e0e0e !important;
    box-shadow: 0 0 20px rgba(210, 188, 251, 0.3);
  }

  /* ============================================================
     Layout helpers
     ============================================================ */
  .section-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .section-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    color: #ededed;
  }

  .section-subtitle {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.875rem;
    color: #a3a3a3;
    letter-spacing: 0.05em;
    margin-top: -1.5rem;
    margin-bottom: 3rem;
  }

  .how-it-works .section-label {
    text-align: center;
  }

  .hidden {
    display: none !important;
  }

  /* ============================================================
     Grain overlay
     ============================================================ */
  .hero::before,
  .for-agents::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.03;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px;
  }

  /* ============================================================
     HERO
     ============================================================ */
  .hero {
    padding: 10rem 2rem 5rem;
    background: #0e0e0e;
    position: relative;
    overflow: hidden;
  }

  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.22;
    pointer-events: none;
    mix-blend-mode: screen;
  }

  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .hero-headline {
    font-size: clamp(2.75rem, 5vw, 4.25rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: #ededed;
    margin-bottom: 2rem;
    text-transform: uppercase;
  }

  .hero-accent {
    color: #d2bcfb;
    text-shadow: 0 0 40px rgba(210, 188, 251, 0.15);
  }

  .hero-sub {
    font-size: 1.125rem;
    color: #a3a3a3;
    max-width: 600px;
    margin-bottom: 3rem;
    line-height: 1.6;
  }

  /* ============================================================
     Terminal component
     ============================================================ */
  .terminal {
    background: #0a0a0a;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(73, 69, 79, 0.12),
      0 8px 48px rgba(0, 0, 0, 0.4),
      0 0 40px rgba(210, 188, 251, 0.02);
  }

  .terminal-chrome {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.65rem 1rem;
    background: #1a1a1a;
    border-bottom: 1px solid rgba(73, 69, 79, 0.1);
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #2a2a2a;
    border: 1px solid rgba(73, 69, 79, 0.2);
  }

  .terminal-dot:first-child { background: #ff5f57; border-color: #e0443e; }
  .terminal-dot:nth-child(2) { background: #febc2e; border-color: #dea123; }
  .terminal-dot:nth-child(3) { background: #28c840; border-color: #1aab29; }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.6875rem;
    color: #49454f;
    letter-spacing: 0.03em;
    margin-right: 30px;
  }

  .terminal-body {
    padding: 1.5rem;
    overflow-x: auto;
  }

  .terminal-body pre {
    margin: 0;
    background: transparent;
  }

  .terminal-body code {
    font-size: 0.8125rem;
    line-height: 1.9;
    color: #c8c8c8;
  }

  .terminal .prompt {
    color: #d2bcfb;
    user-select: none;
  }

  .terminal .comment {
    color: #555;
  }

  .t-cmd { color: #7ec8e3; }
  .t-str { color: #a8d8a8; }
  .t-num { color: #d2bcfb; }
  .t-ok  { color: #28c840; }
  .t-warn { color: #febc2e; }

  /* Scanline overlay on terminals */
  .terminal-body::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.03) 2px,
      rgba(0, 0, 0, 0.03) 4px
    );
  }

  .terminal-body {
    position: relative;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 2rem;
    background: linear-gradient(135deg, #d2bcfb 0%, #b19cd9 100%);
    color: #0e0e0e;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    transition: all 0.25s ease;
    line-height: 1;
    box-shadow: 0 0 0 rgba(210, 188, 251, 0);
  }

  .btn-primary:hover {
    color: #0e0e0e;
    box-shadow: 0 0 24px rgba(210, 188, 251, 0.3);
    transform: translateY(-1px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 2rem;
    background: transparent;
    color: #d2bcfb;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border: 1px solid rgba(73, 69, 79, 0.15);
    cursor: pointer;
    transition: all 0.25s ease;
    line-height: 1;
  }

  .btn-secondary:hover {
    border-color: #d2bcfb;
    background: rgba(210, 188, 251, 0.05);
    color: #d2bcfb;
    box-shadow: 0 0 16px rgba(210, 188, 251, 0.1);
    transform: translateY(-1px);
  }

  .hero-install-hint {
    font-size: 0.875rem;
    color: #737373;
    margin-top: 1.5rem;
  }

  .hero-install-hint code {
    color: #a3a3a3;
    background: #1c1b1b;
    padding: 0.375rem 0.75rem;
    border-left: 2px solid #d2bcfb;
  }

  /* ============================================================
     METRICS STRIP
     ============================================================ */
  .metrics {
    background: #1c1b1b;
    padding: 3rem 2rem;
  }

  .metrics-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: left;
  }

  .metric-label {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    color: #b19cd9;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .metric-value {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.2;
    background: linear-gradient(180deg, #ffffff 0%, #d4d4d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ============================================================
     PITCH
     ============================================================ */
  .pitch {
    padding: 4rem 2rem;
    background: #0e0e0e;
  }

  .pitch-text {
    font-size: 1.25rem;
    line-height: 1.7;
    color: #a3a3a3;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .protocol-badges {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .protocol-badge {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #737373;
    padding: 0.3rem 0.8rem;
    border: 1px solid rgba(73, 69, 79, 0.15);
  }

  /* ============================================================
     THE PROBLEM
     ============================================================ */
  .problem {
    padding: 6rem 2rem;
    background: #0e0e0e;
  }

  .problem-layout {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 3rem;
    align-items: start;
  }

  .problem-text {
  }

  .problem-desc {
    font-size: 1.125rem;
    color: #a3a3a3;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .problem-quote {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    font-style: italic;
    color: #d2bcfb;
    line-height: 1.6;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .problem-table-header {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(73, 69, 79, 0.3);
  }

  .problem-table-header span {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.625rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: #d2bcfb;
    text-transform: uppercase;
  }

  .problem-table {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .problem-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(73, 69, 79, 0.15);
  }

  .problem-row:last-child {
    border-bottom: none;
  }

  .problem-issue {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: #ededed;
    text-transform: uppercase;
  }

  .problem-impact {
    font-size: 0.875rem;
    color: #a3a3a3;
    line-height: 1.5;
  }

  /* ============================================================
     HOW IT WORKS
     ============================================================ */
  .how-it-works {
    padding: 6rem 2rem;
    background: #131313;
    text-align: center;
  }

  .section-label {
    display: block;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: #737373;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .how-it-works .section-title {
    text-align: center;
    margin-bottom: 1rem;
  }

  .section-desc {
    font-size: 1rem;
    color: #737373;
    text-align: center;
    margin-bottom: 2.5rem;
    letter-spacing: 0.01em;
  }

  /* ============================================================
     Demo split: terminal + diagram
     ============================================================ */
  .demo-split {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 2rem;
    margin-bottom: 3.5rem;
    text-align: left;
  }

  .demo-term .terminal {
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .demo-term .terminal-body {
    height: 280px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .demo-term pre {
    margin: 0;
    font-size: 0.75rem;
    line-height: 1.9;
    color: #c8c8c8;
    white-space: pre-wrap;
    word-break: break-all;
  }

  .demo-viz {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: stretch;
    gap: 1.25rem;
    padding: 1.5rem;
    background:
      radial-gradient(circle at 50% 50%, rgba(210, 188, 251, 0.02) 0%, transparent 70%),
      repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(73, 69, 79, 0.04) 39px, rgba(73, 69, 79, 0.04) 40px),
      repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(73, 69, 79, 0.04) 39px, rgba(73, 69, 79, 0.04) 40px);
    border: 1px solid rgba(73, 69, 79, 0.06);
    position: relative;
  }

  .viz-topo {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    transition: opacity 0.6s ease;
  }

  .viz-card {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.75rem 1rem;
    background: #1c1b1b;
    border: 1px solid rgba(73, 69, 79, 0.15);
    position: relative;
    min-width: 80px;
    transition: all 0.5s ease;
  }

  .viz-card-icon {
    font-size: 1rem;
    color: #49454f;
    line-height: 1;
  }

  .viz-card-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.625rem;
    font-weight: 600;
    color: #a3a3a3;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .viz-card-port {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.5625rem;
    color: #49454f;
  }

  .viz-card-primary {
    background: linear-gradient(135deg, #d2bcfb 0%, #b19cd9 100%);
    border-color: transparent;
    box-shadow: 0 0 28px rgba(210, 188, 251, 0.18);
    padding: 0.9rem 1.25rem;
  }

  .viz-card-primary .viz-card-icon { color: #1a1030; }
  .viz-card-primary .viz-card-name { color: #1a1030; font-weight: 700; }
  .viz-card-primary .viz-card-port { color: #2d2045; }

  .viz-card-twin {
    border-color: rgba(40, 200, 64, 0.25);
  }

  .viz-card-twin .viz-card-icon { color: #28c840; }
  .viz-card-twin .viz-card-name { color: #28c840; }
  .viz-card-twin .viz-card-port { color: rgba(40, 200, 64, 0.5); }

  .viz-card-twin.glow {
    box-shadow: 0 0 28px rgba(40, 200, 64, 0.12);
    border-color: rgba(40, 200, 64, 0.4);
  }

  .viz-indicator {
    display: none;
    position: absolute;
    top: -4px;
    right: -4px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .viz-indicator.recording {
    display: block;
    background: #ff5f57;
    box-shadow: 0 0 8px rgba(255, 95, 87, 0.6);
    animation: pulse-dot 1.5s ease-in-out infinite;
  }

  .viz-indicator.synth {
    display: block;
    width: 10px;
    height: 10px;
    border: 2px solid #1a1030;
    border-top-color: transparent;
    background: none;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  .viz-indicator.verified {
    display: block;
    background: #28c840;
    box-shadow: 0 0 6px rgba(40, 200, 64, 0.5);
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .viz-conn {
    flex: 1;
    min-width: 30px;
    height: 20px;
    position: relative;
    display: flex;
    align-items: center;
    transition: opacity 0.5s ease;
  }

  .viz-arrow {
    width: 100%;
    height: 20px;
    color: rgba(73, 69, 79, 0.3);
    transition: color 0.5s ease;
  }

  .viz-conn.active .viz-arrow { color: rgba(210, 188, 251, 0.5); }
  .viz-conn.active-green .viz-arrow { color: rgba(40, 200, 64, 0.4); }

  .viz-middle {
    position: relative;
    min-width: 90px;
    min-height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .viz-middle .viz-card {
    position: absolute;
    transition: opacity 0.5s ease;
  }

  .viz-badge-row {
    text-align: center;
    min-height: 1.5rem;
    width: 100%;
  }

  .viz-hud {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    min-height: 3.5rem;
    width: 100%;
  }

  .viz-counter {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    transition: opacity 0.4s ease;
  }

  .viz-counter-val {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #d2bcfb;
    min-width: 2ch;
    text-align: right;
  }

  .viz-counter-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.625rem;
    font-weight: 500;
    color: #49454f;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .viz-dots {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  @keyframes flow-right {
    0% { left: -10%; opacity: 0; }
    15% { opacity: 1; }
    85% { opacity: 1; }
    100% { left: 95%; opacity: 0; }
  }

  .viz-dots.active::before,
  .viz-dots.active::after {
    content: '';
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #d2bcfb;
    box-shadow: 0 0 10px rgba(210, 188, 251, 0.5);
    animation: flow-right 1.4s ease-in-out infinite;
  }

  .viz-dots.active::after {
    animation-delay: 0.7s;
  }

  .viz-dots.active-green::before,
  .viz-dots.active-green::after {
    content: '';
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #28c840;
