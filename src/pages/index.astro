  @media (max-width: 920px) {
    .hero { padding: 64px 0 56px; }
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .loop { grid-template-columns: 1fr; gap: 40px; }
    .verify { grid-template-columns: 1fr; gap: 40px; }
    .cta-box { grid-template-columns: 1fr; gap: 32px; padding: 48px 32px; }
    .footer-inner { grid-template-columns: 1fr 1fr; gap: 40px; padding: 0 24px; }
