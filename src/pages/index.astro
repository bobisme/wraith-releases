    .cta-row { flex-direction: column; align-items: stretch; }
    .trust-row { gap: 16px; }
  }
</style>

<script>
  (() => {
    // ---- Verify grid ----
    const gridDots = document.getElementById('gridDots');
    if (gridDots) {
      const warns = new Set([14, 29, 47]);
      for (let i = 0; i < 60; i++) {
        const d = document.createElement('div');
        d.className = 'dot' + (warns.has(i) ? ' warn' : '');
        gridDots.appendChild(d);
      }
    }

    // ---- Terminal scripts per phase ----
    // cmd: plain text typed char-by-char. hl: optional pre-highlighted HTML
    // swapped in once typing completes. html: rich output line (innerHTML).
    const TERM_SCRIPTS = [
      {
        mode: 'init',
        lines: [
          {
            prompt: '$',
            cmd: 'wraith init myapi --base-url https://api.example.com',
            hl: '<span class="tk-kw">wraith</span> <span class="tk-sub">init</span> myapi <span class="tk-arg">--base-url</span> <span class="tk-str">https://api.example.com</span>',
          },
          { html: '  <span class="tk-mute">creating</span>  <span class="tk-path">twins/myapi/</span>' },
          { html: '  + <span class="tk-path">wraith.toml</span>  + <span class="tk-path">scrub.toml</span>  + <span class="tk-path">recordings/</span>' },
          { html: '  <span class="ok">&#10003; ready</span>' },
        ],
      },
      {
        mode: 'recording',
        lines: [
          {
            prompt: '$',
            cmd: 'wraith record myapi --port 8080 &',
            hl: '<span class="tk-kw">wraith</span> <span class="tk-sub">record</span> myapi <span class="tk-arg">--port</span> <span class="tk-num">8080</span> <span class="tk-mute">&amp;</span>',
          },
          { html: '  <span class="tk-mute">listening on</span> <span class="tk-num">:8080</span> <span class="tk-arrow">&rarr;</span> <span class="tk-str">api.example.com</span>' },
          { html: '  <span class="tk-mute">scrubbing &middot; 3 layers &middot; pre-write</span>' },
          {
            prompt: '$',
            cmd: 'python exercise.py',
            hl: '<span class="tk-kw">python</span> <span class="tk-str">exercise.py</span>',
          },
          { html: '  <span class="tk-get">GET</span>  <span class="tk-str">/customers</span>         <span class="tk-arrow">&rarr;</span> <span class="tk-status2xx">200</span> <span class="tk-mute">&middot; 142ms</span>' },
          { html: '  <span class="tk-post">POST</span> <span class="tk-str">/customers</span>         <span class="tk-arrow">&rarr;</span> <span class="tk-status2xx">201</span> <span class="tk-mute">&middot; 89ms</span>' },
          { html: '  <span class="tk-get">GET</span>  <span class="tk-str">/customers/42</span>      <span class="tk-arrow">&rarr;</span> <span class="tk-status2xx">200</span> <span class="tk-mute">&middot; 37ms</span>' },
          { html: '  <span class="ok">session 1 &middot; 247 exchanges</span>' },
        ],
      },
      {
        mode: 'synthesizing',
        lines: [
          {
            prompt: '$',
            cmd: 'wraith synth myapi',
            hl: '<span class="tk-kw">wraith</span> <span class="tk-sub">synth</span> myapi',
          },
          { html: '  <span class="tk-mute">anti-unify</span>      <span class="tk-num">4</span> sessions &middot; <span class="tk-num">247</span> exchanges' },
          { html: '  <span class="tk-mute">classify holes</span>  echoed: <span class="tk-num">412</span>  gen: <span class="tk-num">89</span>  ts: <span class="tk-num">34</span>' },
          { html: '  <span class="tk-mute">infer state</span>     <span class="tk-num">22</span> CRUD ops &middot; <span class="tk-num">7</span> entity types' },
          { html: '  <span class="ok">&#10003; <span class="tk-num">25</span> routes &middot; <span class="tk-num">2146</span> symbols</span>' },
        ],
      },
      {
        mode: 'checking',
        lines: [
          {
            prompt: '$',
            cmd: 'wraith check myapi --in-memory',
            hl: '<span class="tk-kw">wraith</span> <span class="tk-sub">check</span> myapi <span class="tk-arg">--in-memory</span>',
          },
          { html: '  <span class="ok">[PASS]</span> myapi: <span class="tk-num">4/4</span> sessions passed (<span class="tk-num">100%</span>)' },
          { html: '  <span class="tk-mute">divergences:</span> <span class="tk-num">3</span>' },
          { html: '    <span class="tk-mute">extra_field</span>   <span class="tk-num">2</span> <span class="tk-warn">(warning)</span>' },
          { html: '    <span class="tk-mute">type_mismatch</span> <span class="tk-num">1</span> <span class="tk-warn">(warning)</span>' },
          { html: '  <span class="ok">exit 0</span>' },
        ],
      },
      {
        mode: 'live',
        lines: [
          {
            prompt: '$',
            cmd: 'wraith serve myapi --port 8081',
            hl: '<span class="tk-kw">wraith</span> <span class="tk-sub">serve</span> myapi <span class="tk-arg">--port</span> <span class="tk-num">8081</span>',
          },
          { html: '  <span class="tk-mute">twin serving on</span> <span class="tk-num">:8081</span>' },
          { html: '  <span class="tk-mute">fidelity</span>   synth &middot; state engine' },
          { html: '  <span class="tk-mute">routes</span>     <span class="tk-num">25</span> &middot; symbols <span class="tk-num">2146</span>' },
          { html: '  <span class="ok">&#9656; ready. point your tests at localhost</span>' },
        ],
      },
    ];

    let curStep = 0;
    let curLineIdx = 0;
    let typeTimer = null;
    let recordTicker = null;

    const escape = (s) =>
      String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function renderStep(idx) {
      document.querySelectorAll('.step').forEach((el, i) => {
        el.classList.toggle('active', i === idx);
        el.setAttribute('aria-pressed', String(i === idx));
      });
      const modeEl = document.getElementById('vizMode');
      if (modeEl) modeEl.textContent = TERM_SCRIPTS[idx].mode;

      updateFlowViz(idx);

      const term = document.getElementById('term');
      if (!term) return;
      term.innerHTML = '';
      curLineIdx = 0;
      typeNext(term, TERM_SCRIPTS[idx].lines);
    }

    function typeNext(term, lines) {
      if (typeTimer) clearTimeout(typeTimer);
      if (curLineIdx >= lines.length) {
        const caret = document.createElement('div');
        caret.className = 'line';
        caret.innerHTML = '<span class="prompt">$</span><span><span class="caret"></span></span>';
        term.appendChild(caret);
        return;
      }
      const line = lines[curLineIdx];
      const div = document.createElement('div');

      if (line.prompt) {
        div.className = 'line';
        div.innerHTML = `<span class="prompt">${line.prompt}</span><span class="cmd"></span>`;
        term.appendChild(div);
        const target = div.querySelector('.cmd');
        typeText(target, line.cmd, () => {
          // Swap typed text for highlighted version once typing completes
          if (line.hl) target.innerHTML = line.hl;
          curLineIdx++;
          typeTimer = setTimeout(() => typeNext(term, lines), 180);
        });
      } else {
        div.className = 'out';
        if (line.html) div.innerHTML = line.html;
        else if (line.ok) div.innerHTML = `<span class="ok">${escape(line.out)}</span>`;
        else div.innerHTML = escape(line.out);
        term.appendChild(div);
        curLineIdx++;
        typeTimer = setTimeout(() => typeNext(term, lines), 150);
      }
    }

    function typeText(el, text, done) {
      let i = 0;
      const step = reducedMotion ? 0 : 1;
      const delay = () => (reducedMotion ? 0 : 18 + Math.random() * 12);
      function tick() {
        el.textContent = text.slice(0, i);
        i += step || 1;
        if (i <= text.length) {
          if (reducedMotion) {
            el.textContent = text;
            done && done();
          } else {
            typeTimer = setTimeout(tick, delay());
          }
        } else done && done();
      }
      tick();
    }

    let loopTimer = null;
    function startLoop() {
      renderStep(curStep);
      loopTimer = setInterval(() => {
        curStep = (curStep + 1) % TERM_SCRIPTS.length;
        renderStep(curStep);
        syncVizDots();
      }, 7500);
    }
    function restartLoop() {
      if (loopTimer) clearInterval(loopTimer);
      loopTimer = setInterval(() => {
        curStep = (curStep + 1) % TERM_SCRIPTS.length;
        renderStep(curStep);
        syncVizDots();
      }, 7500);
    }
    function gotoStep(i) {
      curStep = ((i % TERM_SCRIPTS.length) + TERM_SCRIPTS.length) % TERM_SCRIPTS.length;
      renderStep(curStep);
      syncVizDots();
      restartLoop();
    }

    function syncVizDots() {
      document.querySelectorAll('#vizDots .pd').forEach((d, i) => {
        d.classList.toggle('active', i === curStep);
      });
    }

    // Build phase dots + wire arrows
    const dotsEl = document.getElementById('vizDots');
    if (dotsEl) {
      for (let i = 0; i < TERM_SCRIPTS.length; i++) {
        const d = document.createElement('button');
        d.type = 'button';
        d.className = 'pd' + (i === 0 ? ' active' : '');
        d.dataset.i = String(i);
        d.setAttribute('aria-label', `phase ${i + 1}`);
        d.addEventListener('click', () => gotoStep(Number(d.dataset.i)));
        dotsEl.appendChild(d);
      }
      const prev = document.getElementById('vizPrev');
      const next = document.getElementById('vizNext');
      if (prev) prev.addEventListener('click', () => gotoStep(curStep - 1));
      if (next) next.addEventListener('click', () => gotoStep(curStep + 1));
    }

    // Click step rows to jump
    document.querySelectorAll('.step').forEach(el => {
      el.addEventListener('click', () => gotoStep(Number(el.dataset.i)));
    });

    document.querySelectorAll('[data-copy-install]').forEach((button) => {
      button.addEventListener('click', async () => {
        const command = 'curl -fsSL https://wraith.cx/install.sh | sh';
        try {
          await navigator.clipboard.writeText(command);
          button.textContent = 'copied';
        } catch {
          button.textContent = 'copy failed';
        }
        window.wraithTrack?.('install_command_copy', { source: 'homepage_install_card' });
        setTimeout(() => { button.textContent = 'copy command'; }, 1800);
      });
    });

    // ---- Build tape rows and conformance grid once ----
    (function buildVizExtras() {
      const tape = document.getElementById('tape-rows');
      if (tape) {
        const exchanges = [
          { m: 'GET',  p: '/users',           s: '200', t: '142ms' },
          { m: 'POST', p: '/users',           s: '201', t: '89ms'  },
          { m: 'GET',  p: '/users/42',        s: '200', t: '37ms'  },
          { m: 'POST', p: '/orders',          s: '201', t: '118ms' },
          { m: 'POST', p: '/payments',        s: '201', t: '204ms' },
          { m: 'GET',  p: '/orders/7/items',  s: '200', t: '52ms'  },
          { m: 'PATCH',p: '/refunds/r_9x2',   s: '200', t: '76ms'  },
          { m: 'GET',  p: '/sessions',        s: '200', t: '23ms'  },
          { m: 'DEL',  p: '/sessions/abc',    s: '204', t: '14ms'  },
          { m: 'GET',  p: '/invoices/i_01',   s: '200', t: '61ms'  },
        ];
        const colors = { GET: '#7df9ff', POST: '#f6b861', PATCH: '#a78bfa', DEL: '#e06c75' };
        exchanges.forEach((ex, i) => {
          const y = i * 16;
          const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
          g.setAttribute('class', 'tape-row');
          g.setAttribute('transform', `translate(20, ${y})`);
          g.setAttribute('opacity', '0');
          g.innerHTML = `
            <text x="0" y="0" font-family="JetBrains Mono" font-size="9" fill="${colors[ex.m] || '#9ba6b6'}">${ex.m}</text>
            <text x="44" y="0" font-family="JetBrains Mono" font-size="9" fill="#e7ecf3">${ex.p}</text>
            <text x="280" y="0" font-family="JetBrains Mono" font-size="9" fill="#5eead4">${ex.s}</text>
            <text x="330" y="0" font-family="JetBrains Mono" font-size="9" fill="#6b7789">${ex.t}</text>
            <line x1="0" y1="4" x2="400" y2="4" stroke="#1e2430" stroke-width=".5"/>
          `;
          tape.appendChild(g);
        });
      }

      const cells = document.getElementById('conformance-cells');
      if (cells) {
        const W = 18, gap = 2;
        const cols = 20, rows = 5;
        const warnIdx = new Set([12, 47, 63]);
        for (let r = 0; r < rows; r++) {
          for (let c = 0; c < cols; c++) {
            const i = r * cols + c;
            const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
            rect.setAttribute('x', String(c * (W + gap)));
            rect.setAttribute('y', String(16 + r * (W + gap)));
            rect.setAttribute('width', String(W));
            rect.setAttribute('height', String(W));
            rect.setAttribute('fill', warnIdx.has(i) ? '#f6b861' : '#5eead4');
            rect.setAttribute('opacity', '0');
            rect.setAttribute('class', 'conf-cell');
            rect.dataset.i = String(i);
            cells.appendChild(rect);
          }
        }
      }
    })();

    function stopTicker() {
      if (recordTicker) { clearInterval(recordTicker); recordTicker = null; }
    }

    function updateFlowViz(step) {
      const W = document.getElementById('w-body');
      const WRing = document.getElementById('w-ring');
      const WHalo = document.getElementById('w-halo');
      const WFill = document.getElementById('w-fill');
      const nodeReal = document.getElementById('node-real');
      const nodeTwin = document.getElementById('node-twin');
      const lineTwin = document.getElementById('line-wraith-twin');
      const reqPkts = document.getElementById('req-pkts');
      const respPkts = document.getElementById('resp-pkts');
      const twinPkts = document.getElementById('twin-pkts');
      const tapeRecord = document.getElementById('tape-record');
      const treeLearn = document.getElementById('tree-learn');
      const gridServe = document.getElementById('grid-serve');
      const label = document.getElementById('phaseLabel');
      const count = document.getElementById('phaseCount');
      const laneLabel = document.getElementById('lane-label');
      const laneCounter = document.getElementById('lane-counter');
      const wraithNode = document.getElementById('node-wraith');
      const wTittle = document.getElementById('w-tittle');
      const wPort = document.getElementById('w-port');
      const recDot = document.getElementById('w-rec');
      const synthRing = document.getElementById('w-synth-ring');

      if (!W) return;
      stopTicker();

      tapeRecord.style.opacity = '0';
      treeLearn.style.opacity = '0';
      gridServe.style.opacity = '0';

      if (step === 0) {
        // INIT — quiet scaffolding, ghost wraith, no traffic
        W.setAttribute('stroke-dasharray', '2 3');
        W.setAttribute('stroke', '#7df9ff');
        W.setAttribute('stroke-width', '1');
        WRing.setAttribute('stroke', '#7df9ff');
        WRing.style.opacity = '.25';
        WHalo.setAttribute('fill', 'url(#glow-cyan)');
        WHalo.style.opacity = '.15';
        WFill.style.opacity = '0';
        if (wraithNode) wraithNode.style.opacity = '.75';
        if (wTittle) wTittle.setAttribute('fill', '#7df9ff');
        if (wPort) wPort.setAttribute('fill', '#6b7789');
        if (recDot) recDot.style.opacity = '0';
        if (synthRing) synthRing.style.opacity = '0';

        nodeReal.style.opacity = '.6';
        nodeTwin.style.opacity = '0';
        lineTwin.style.opacity = '0';
        reqPkts.style.opacity = '0';
        respPkts.style.opacity = '0';
        twinPkts.style.opacity = '0';

        laneLabel.textContent = 'SCAFFOLDING TWIN';
        laneLabel.setAttribute('fill', '#6b7789');
        laneCounter.textContent = 'twins/myapi/ · config';
        laneCounter.setAttribute('fill', '#6b7789');

        label.textContent = 'PHASE 00 · INIT';
        label.setAttribute('fill', '#6b7789');
        count.textContent = 'scaffold created · ready to record';
      } else if (step === 1) {
        // RECORD — coral-red wraith, REC indicator, capture tape
        W.setAttribute('stroke-dasharray', '0');
        W.setAttribute('stroke', '#f87171');
        W.setAttribute('stroke-width', '1.4');
        WRing.setAttribute('stroke', '#f87171');
        WRing.style.opacity = '.55';
        WHalo.style.opacity = '.5';
        WHalo.setAttribute('fill', 'url(#glow-red)');
        WFill.style.opacity = '0';
        if (wraithNode) wraithNode.style.opacity = '1';
        if (wTittle) wTittle.setAttribute('fill', '#f87171');
        if (wPort) wPort.setAttribute('fill', '#f87171');
        if (recDot) recDot.style.opacity = '1';
        if (synthRing) synthRing.style.opacity = '0';

        nodeReal.style.opacity = '1';
        nodeTwin.style.opacity = '0';
        lineTwin.style.opacity = '0';
        reqPkts.style.opacity = '1';
        respPkts.style.opacity = '1';
        twinPkts.style.opacity = '0';

        tapeRecord.style.opacity = '1';
        laneLabel.textContent = 'CAPTURED · SESSION 01';
        laneLabel.setAttribute('fill', '#7df9ff');
        laneCounter.setAttribute('fill', '#7df9ff');

        const rows = tapeRecord.querySelectorAll('.tape-row');
        rows.forEach(r => r.setAttribute('opacity', '0'));
        let idx = 0;
        const show = () => {
          if (idx >= rows.length) return;
          rows[idx].setAttribute('opacity', '1');
          idx++;
          laneCounter.textContent = `${idx * 25} exchanges`;
        };
        show();
        recordTicker = setInterval(show, 360);

        label.textContent = 'PHASE 01 · RECORD';
        label.setAttribute('fill', '#7df9ff');
        count.textContent = 'capturing real traffic · 247 exchanges';
      } else if (step === 2) {
        // LEARN — solidifying, violet, schemas + routes cascade
        W.setAttribute('stroke-dasharray', '0');
        W.setAttribute('stroke', '#a78bfa');
        W.setAttribute('stroke-width', '1.2');
        WRing.setAttribute('stroke', '#a78bfa');
        WRing.style.opacity = '.25';
        WHalo.setAttribute('fill', 'url(#glow-violet)');
        WHalo.style.opacity = '.5';
        WFill.setAttribute('fill', 'url(#glow-violet)');
        WFill.style.opacity = '.2';
        if (wraithNode) wraithNode.style.opacity = '1';
        if (recDot) recDot.style.opacity = '0';
        if (wTittle) wTittle.setAttribute('fill', '#a78bfa');
        if (wPort) wPort.setAttribute('fill', '#a78bfa');
        if (synthRing) {
          synthRing.style.opacity = '1';
          synthRing.setAttribute('stroke-dashoffset', '333');
          const startT = performance.now();
          const dur = 5200;
          const tick = (t) => {
            const p = Math.min(1, (t - startT) / dur);
            const eased = 1 - Math.pow(1 - p, 2);
            synthRing.setAttribute('stroke-dashoffset', String(333 * (1 - eased)));
            if (p < 1 && curStep === 2) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        }

        nodeReal.style.opacity = '.45';
        nodeTwin.style.opacity = '0';
        lineTwin.style.opacity = '0';
        reqPkts.style.opacity = '.15';
        respPkts.style.opacity = '.15';
        twinPkts.style.opacity = '0';

        treeLearn.style.opacity = '1';
        laneLabel.textContent = 'SYNTHESIZING MODEL';
        laneLabel.setAttribute('fill', '#a78bfa');
        laneCounter.textContent = '25 routes · 2146 symbols';
        laneCounter.setAttribute('fill', '#a78bfa');

        const schemaRows = treeLearn.querySelectorAll('.schema-row');
        const routeRows = treeLearn.querySelectorAll('.route-row');
        [...schemaRows, ...routeRows].forEach(r => r.setAttribute('opacity', '0'));
        const all = [...schemaRows, ...routeRows];
        let i = 0;
        const cascade = () => {
          if (i >= all.length) return;
          all[i].setAttribute('opacity', '1');
          i++;
        };
        cascade();
        recordTicker = setInterval(cascade, 120);

        label.textContent = 'PHASE 02 · LEARN';
        label.setAttribute('fill', '#a78bfa');
        count.textContent = 'anti-unifying · classifying holes · inferring state';
      } else if (step === 3) {
        // CHECK — mint, conformance grid fills
        W.setAttribute('stroke-dasharray', '0');
        W.setAttribute('stroke', '#5eead4');
        W.setAttribute('stroke-width', '1.2');
        WRing.setAttribute('stroke', '#5eead4');
        WRing.style.opacity = '.2';
        WHalo.setAttribute('fill', 'url(#glow-violet)');
        WHalo.style.opacity = '.5';
        WFill.setAttribute('fill', 'url(#glow-violet)');
        WFill.style.opacity = '.25';
        if (wraithNode) wraithNode.style.opacity = '1';
        if (recDot) recDot.style.opacity = '0';
        if (synthRing) synthRing.style.opacity = '.4';
        if (wTittle) wTittle.setAttribute('fill', '#5eead4');
        if (wPort) wPort.setAttribute('fill', '#5eead4');

        nodeReal.style.opacity = '.3';
        nodeTwin.style.opacity = '.7';
        lineTwin.style.opacity = '.4';
        reqPkts.style.opacity = '.1';
        respPkts.style.opacity = '.1';
        twinPkts.style.opacity = '0';

        gridServe.style.opacity = '1';
        laneLabel.textContent = 'CHECK · TWIN vs. REAL';
        laneLabel.setAttribute('fill', '#5eead4');
        laneCounter.textContent = '100% pass';
        laneCounter.setAttribute('fill', '#5eead4');

        const cells = gridServe.querySelectorAll('.conf-cell');
        cells.forEach(c => c.setAttribute('opacity', '0'));
        let i = 0;
        const reveal = () => {
          if (i >= cells.length) return;
          cells[i].setAttribute('opacity', '.85');
          i++;
        };
        reveal();
        recordTicker = setInterval(reveal, 18);

        label.textContent = 'PHASE 03 · CHECK';
        label.setAttribute('fill', '#5eead4');
        count.textContent = '4/4 sessions passed · 3 warnings · exit 0';
      } else {
        // SERVE — fully materialized twin
        W.setAttribute('stroke-dasharray', '0');
        W.setAttribute('stroke', '#a78bfa');
        W.setAttribute('stroke-width', '1.6');
        WRing.setAttribute('stroke', '#a78bfa');
        WRing.style.opacity = '.6';
        WHalo.setAttribute('fill', 'url(#glow-violet)');
        WHalo.style.opacity = '.8';
        WFill.setAttribute('fill', 'url(#glow-violet)');
        WFill.style.opacity = '.55';
        if (wraithNode) wraithNode.style.opacity = '1';
        if (recDot) recDot.style.opacity = '0';
        if (synthRing) {
          synthRing.style.opacity = '.9';
          synthRing.setAttribute('stroke-dashoffset', '0');
        }
        if (wTittle) wTittle.setAttribute('fill', '#a78bfa');
        if (wPort) wPort.setAttribute('fill', '#a78bfa');

        nodeReal.style.opacity = '.2';
        nodeTwin.style.opacity = '1';
        lineTwin.style.opacity = '1';
        reqPkts.style.opacity = '0';
        respPkts.style.opacity = '0';
        twinPkts.style.opacity = '1';

        gridServe.style.opacity = '1';
        gridServe.querySelectorAll('.conf-cell').forEach(c => c.setAttribute('opacity', '.85'));
        laneLabel.textContent = 'TWIN LIVE · DETERMINISTIC';
        laneLabel.setAttribute('fill', '#a78bfa');
        laneCounter.textContent = '0ms p50 · exit 0';
        laneCounter.setAttribute('fill', '#a78bfa');

        label.textContent = 'PHASE 04 · SERVE';
        label.setAttribute('fill', '#a78bfa');
        count.textContent = 'twin on :8081 · deterministic · stateful · 0ms first byte';
      }
    }

    startLoop();
  })();
</script>
